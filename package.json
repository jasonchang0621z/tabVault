{
  "name": "tabvault",
  "version": "1.0.0",
  "description": "Save and restore tab workspaces with Chrome native tab groups",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wxt": "^0.20.18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "eslint": "^9.39.3",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
